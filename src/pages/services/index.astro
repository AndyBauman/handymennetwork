---
import BaseLayout from "@/layouts/BaseLayout.astro";
import MenuCard from "@/components/MenuCard.astro";
import AddToCartButton from "@/components/AddToCartButton";
import { menuCategories, bundles } from "@/data/menu";
import { SITE_NAME } from "@/data/constants";

const title = `Browse repairs — menu pricing — ${SITE_NAME}`;
const description =
  "Drywall, doors, trim, general repairs, furniture assembly, exterior work, and money-saving bundles — all with fixed prices.";
---

<BaseLayout title={title} description={description}>
  <header class="max-w-3xl">
    <h1 class="font-display text-4xl font-bold text-brand-green">The repair menu</h1>
    <p class="mt-4 text-xl">
      Every line shows price, time, what's included, and whether basic materials are included or you
      supply them. Not sure? Use Help in the app or "custom help" on the book page.
    </p>
  </header>

  {
    menuCategories.map((cat) => (
      <section class="mt-14" id={cat.slug} aria-labelledby={`cat-${cat.slug}`}>
        <h2 id={`cat-${cat.slug}`} class="font-display text-3xl font-bold text-brand-green">
          <span aria-hidden="true">{cat.emoji}</span> {cat.title}
        </h2>
        <div class="mt-6 grid gap-6 lg:grid-cols-2">
          {cat.items.map((item) => (
            <MenuCard item={item} />
          ))}
        </div>
      </section>
    ))
  }

  <section class="mt-16" aria-labelledby="bundles-heading">
    <h2 id="bundles-heading" class="font-display text-3xl font-bold text-brand-green">
      Bundles and time blocks
    </h2>
    <p class="mt-3 text-lg">Save when you stack work — or buy hours for mixed small tasks.</p>
    <ul class="mt-6 grid gap-6 lg:grid-cols-2">
      {
        bundles.map((b) => (
          <li class="rounded-2xl border-2 border-brand-amber/40 bg-brand-cream p-6 shadow-sm">
            <h3 class="font-display text-2xl font-bold text-brand-green">{b.name}</h3>
            {b.savings && <p class="mt-2 font-semibold text-brand-green">{b.savings}</p>}
            <p class="mt-3 text-lg">{b.included}</p>
            <p class="mt-4 text-2xl font-bold text-brand-green">${b.price}</p>
            <div class="mt-4">
              <AddToCartButton
                client:load
                id={b.id}
                name={b.name}
                price={b.price}
                type="bundle"
              />
            </div>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
