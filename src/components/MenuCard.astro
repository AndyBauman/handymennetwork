---
import type { MenuItem } from "@/data/menu";
import AddToCartButton from "@/components/AddToCartButton";

interface Props {
  item: MenuItem;
}
const { item } = Astro.props;
const materials =
  item.materials === "basic"
    ? "Basic materials included where noted"
    : "You provide materials (see description)";
---

<article
  class="rounded-2xl border-2 border-brand-green/20 bg-white p-5 shadow-sm hover:shadow-md transition-shadow"
>
  <h3 class="font-display text-menu-title font-bold text-brand-green">
    {item.name}
  </h3>
  <p class="mt-3 text-lg text-brand-charcoal">{item.included}</p>
  <dl class="mt-4 grid gap-1 text-lg">
    <div class="flex flex-wrap justify-between gap-2">
      <dt class="font-semibold">Price</dt>
      <dd class="font-bold text-brand-green text-xl">${item.price}</dd>
    </div>
    <div class="flex flex-wrap justify-between gap-2">
      <dt class="font-semibold">Time</dt>
      <dd>{item.time}</dd>
    </div>
    <div class="mt-2 text-base text-brand-charcoal/90">
      <span class="font-semibold">Materials:</span>
      {materials}
    </div>
  </dl>
  <div class="mt-5">
    <AddToCartButton
      client:load
      id={item.id}
      name={item.name}
      price={item.price}
      type="item"
    />
  </div>
</article>
